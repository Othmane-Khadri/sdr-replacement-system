# SDR Replacement System — Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# UNIPILE — LinkedIn Automation
# Sign up: https://www.unipile.com/?utm_source=partner&utm_campaign=Yalc
# ============================================
UNIPILE_API_KEY=your_unipile_access_token_here
UNIPILE_DSN=https://api4.unipile.com:13443

# ============================================
# CRUSTDATA — Company & People Intelligence
# Sign up: https://crustdata.com
# ============================================
CRUSTDATA_API_KEY=your_crustdata_api_token_here

# ============================================
# FULLENRICH — Email & Phone Enrichment
# Sign up: https://fullenrich.com?via=sNO0yIysrHzw
# ============================================
FULLENRICH_API_KEY=your_fullenrich_api_key_here

# ============================================
# NOTION (Optional) — CRM Layer
# Create integration: https://www.notion.so/my-integrations
# ============================================
# NOTION_API_KEY=ntn_your_integration_token_here
